{
  "name": "rustlings",
  "version": "1.0.0",
  "description": "Интерактивный учебник Rust + Web3",
  "private": true,
  "scripts": {
    "lint": "eslint static/js/**/*.js",
    "lint:fix": "eslint static/js/**/*.js --fix",
    "format": "prettier --check \"static/**/*.{js,json,css,html,md}\"",
    "format:write": "prettier --write \"static/**/*.{js,json,css,html,md}\""
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3"
  }
}
